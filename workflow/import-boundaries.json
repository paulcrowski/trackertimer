{
  "enabled": true,
  "sourceRoots": ["src"],
  "extensions": [".ts", ".tsx", ".js", ".jsx"],
  "aliases": {
    "@/src/": "src/",
    "@/": ""
  },
  "layers": [
    {
      "name": "ui",
      "files": ["src/*.tsx", "src/*.jsx", "src/app/**", "src/pages/**", "src/ui/**", "src/components/**"],
      "allow": ["ui", "business", "domain", "shared"]
    },
    {
      "name": "business",
      "files": ["src/business/**", "src/services/**"],
      "allow": ["business", "domain", "shared"]
    },
    {
      "name": "domain",
      "files": ["src/domain/**", "src/core/**"],
      "allow": ["domain", "shared"]
    },
    {
      "name": "data",
      "files": ["src/data/**", "src/adapters/**", "src/providers/**"],
      "allow": ["data", "domain", "shared"]
    },
    {
      "name": "shared",
      "files": ["src/shared/**"],
      "allow": ["shared"]
    }
  ],
  "ignore": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"]
}
