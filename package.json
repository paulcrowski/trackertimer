{
  "name": "worktimer",
  "private": true,
  "version": "0.0.0",
  "description": "Work timer with Google sync, private local mode, CSV export, Pomodoro, and an optional desktop helper.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:production": "VITE_CONVEX_URL=https://uncommon-cuttlefish-79.convex.cloud vite build",
    "deploy:production": "npm run build:production && wrangler pages deploy dist --project-name worktimer --branch main",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "helper": "node worktimer-helper.mjs",
    "typecheck": "tsc --noEmit --pretty false",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'convex/*.ts' 'scripts/**/*.mjs' 'tests/**/*.{ts,tsx}' 'vite.config.ts' 'tsconfig.json' 'package.json' 'eslint.config.js'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'convex/*.ts' 'scripts/**/*.mjs' 'tests/**/*.{ts,tsx}' 'vite.config.ts' 'tsconfig.json' 'package.json' 'eslint.config.js'",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'convex/*.ts' 'scripts/**/*.mjs' 'tests/**/*.{ts,tsx}' 'vite.config.ts'",
    "smoke": "npm run build && node scripts/smoke-test.mjs",
    "test": "tsx --test tests/**/*.test.ts tests/**/*.test.tsx",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build && node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94",
    "convex": "^1.42.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.2.3"
  }
}
